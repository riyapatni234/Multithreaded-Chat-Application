# Chat Application Configuration - EXAMPLE
# Copy this file to config.properties and fill in your actual values

gemini.api.key=YOUR_GEMINI_API_KEY_HERE
gemini.rate.limit.seconds=5
server.host=localhost
server.port=5555

# Database Configuration
db.url=jdbc:postgresql://localhost:5432/chatapp
db.user=your_database_user
db.password=your_database_password
